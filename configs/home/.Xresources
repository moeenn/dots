*font: xft:JetBrains Mono:style=Regular:size=8
*allowBoldFonts: false
*.scaleHeight: 1.3

!! XTerm settings. 
Xft.dpi: 116
Xft.antialias: 1
Xft.hinting: 1
Xft.hintstyle: hintslight
Xft.rgba: rgb
Xft.lcdfilter: lcddefault
xterm*geometry: 126x26
xterm*selectToClipboard: true
XTerm*internalBorder: 4

!! theme: monokai.
*background: #272822
*foreground: #F8F8F2
*color0:  #272822
*color1:  #F92672
*color2:  #A6E22E
*color3:  #F4BF75
*color4:  #66D9EF
*color5:  #AE81FF
*color6:  #A1EFE4
*color7:  #F8F8F2
*color8:  #75715E
*color9:  #FF6188
*color10: #A9DC76
*color11: #FFD866
*color12: #FC9867
*color13: #AB9DF2
*color14: #78DCE8
*color15: #F9F8F4