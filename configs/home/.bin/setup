# -------------------------------------------------------------------------------------------------------
#
#  helper variables and functions.
#
# -------------------------------------------------------------------------------------------------------
COLOR_RESET = "\033[0m"
COLOR_BLACK = "\033[30m"
COLOR_RED = "\033[31m"
COLOR_BLUE = "\033[34m"


class IConfig(Protocol):
    def name(self) -> str: ...
    def apply(self) -> None: ...


def confirm(message: str) -> bool:
    raw = input(f"{COLOR_BLUE}{message}? [y/n] {COLOR_RESET}")
    return raw.lower().strip() == "y"


def exec(cmd: list[str]) -> None:
    print(f"{COLOR_BLUE}running: {' '.join(cmd)}{COLOR_RESET}")
    _ = subprocess.run(cmd)


def current_user() -> str:
    user = os.getenv("USER")
    if user is None:
        raise Exception("failed to read $USER from environment")
    return user.strip()


def get_home() -> str:
    home = os.getenv("HOME")
    if home is None:
        raise Exception("failed to read $HOME from environment")
    return home.strip()


# -------------------------------------------------------------------------------------------------------
#
#  configurations container classes.
#
# -------------------------------------------------------------------------------------------------------


@dataclass
class SystemPackagesConfig(IConfig):
    base_packages: list[str]
    common_apps: list[str]

    @override
    def name(self) -> str:
        return "System packages"

    def __update_pm_mirrors(self) -> None:
        exec(["sudo", "apt-get", "update", "-y"])

    def __install_packagse(self) -> None:
        cmd = ["sudo", "apt-get", "install", "-y"] + self.base_packages
        exec(cmd)

    def __install_common_apps(self) -> None:
        cmd = ["sudo", "apt-get", "install", "-y"] + self.common_apps
        exec(cmd)

    @override
    def apply(self) -> None:
        if confirm("Update mirrors"):
            self.__update_pm_mirrors()

        if confirm("Install base packages"):
            self.__install_packagse()

        if confirm("Install common apps"):
            self.__install_common_apps()


@dataclass
class FlatpakConfig(IConfig):
    packages: list[str]

    @override
    def name(self) -> str:
        return "Flatpak"

    def __install_support(self) -> None:
        cmd = ["sudo", "apt-get", "install", "-y", "flatpak"]
        exec(cmd)

    def __add_default_repo(self) -> None:
        cmd = [
            "sudo",
            "flatpak",
            "remote-add",
            "--if-not-exists",
            "flathub",
            "https://dl.flathub.org/repo/flathub.flatpakrepo",
        ]
        exec(cmd)

    def __install_flatpaks(self) -> None:
        cmd = ["sudo", "flatpak", "install", "flathub", "-y"] + self.packages
        exec(cmd)

    @override
    def apply(self) -> None:
        if confirm("Install flatpak support"):
            self.__install_support()
            self.__add_default_repo()

        if confirm("Install flatpaks"):
            self.__install_flatpaks()


@dataclass
class DockerConfig(IConfig):
    system_packages: list[str]

    @override
    def name(self) -> str:
        return "Docker"

    def __install_support(self) -> None:
        cmd = ["sudo", "apt-get", "install", "-y"] + self.system_packages
        exec(cmd)

    def __add_docker_group(self) -> None:
        cmd = ["sudo", "groupadd", "docker"]
        exec(cmd)

    def __add_to_group(self) -> None:
        user = current_user()
        cmd = ["sudo", "usermod", "-aG", "docker", user]
        exec(cmd)

    @override
    def apply(self) -> None:
        if confirm("Install docker support"):
            self.__install_support()
            self.__add_docker_group()
            self.__add_to_group()


@dataclass
class FishConfig(IConfig):
    @override
    def name(self) -> str:
        return "Fish (shell)"

    def __install_support(self) -> None:
        cmd = ["sudo", "apt-get", "install", "-y", "fish"]
        exec(cmd)

    def __whereis_fish(self) -> str:
        result = subprocess.run(["which", "fish"], capture_output=True)
        return result.stdout.decode("utf-8").strip()

    @override
    def apply(self) -> None:
        if confirm("Install fish shell"):
            self.__install_support()
            fish_location = self.__whereis_fish()
            user = current_user()
            cmd = ["sudo", "usermod", "-s", fish_location, user]
            exec(cmd)


@dataclass
class GoConfig(IConfig):
    version: str
    packages: list[str]

    @override
    def name(self) -> str:
        return "Golang"

    def __download_tarball(self) -> str:
        filename = f"go{self.version}.linux-amd64.tar.gz"
        url = f"https://go.dev/dl/{filename}"
        download_path = os.path.join(tempfile.gettempdir(), filename)

        if not os.path.exists(download_path):
            cmd = ["wget", url, "-O", download_path]
            exec(cmd)
        return download_path

    def __extract_tarball(self, filepath: str) -> None:
        out_dir = os.path.join(get_home(), ".local")
        out_fullpath = os.path.join(out_dir, "go")

        if os.path.exists(out_fullpath):
            shutil.rmtree(out_fullpath)

        cmd = ["tar", "-xvzf", filepath, "-C", out_dir]
        exec(cmd)

    def __install_packages(self) -> None:
        gopath = os.path.join(get_home(), ".local", "go", "bin", "go")
        for pkg in self.packages:
            cmd = [gopath, "install", "-v", pkg]
            exec(cmd)

    @override
    def apply(self) -> None:
        if confirm("Install go"):
            download_path = self.__download_tarball()
            self.__extract_tarball(download_path)

        if confirm("Install go packages"):
            self.__install_packages()


@dataclass
class NodeJsConfig(IConfig):
    version: str
    global_deps: list[str]

    @override
    def name(self) -> str:
        return "NodeJs"

    def __download_installer(self) -> str:
        out_filename = "nodesource_setup.sh"
        out_filepath = os.path.join(tempfile.gettempdir(), out_filename)
        if not os.path.exists(out_filepath):
            cmd = [
                "curl",
                "-sL",
                f"https://deb.nodesource.com/setup_{self.version}.x",
                "-o",
                out_filepath,
            ]
            exec(cmd)
        return out_filepath

    def __install_sources(self, installer_path: str) -> None:
        cmd = ["sudo", "bash", installer_path]
        exec(cmd)

    def __install_support(self) -> None:
        cmd = ["sudo", "apt-get", "install", "-y", "nodejs"]
        exec(cmd)

    def __set_configs(self) -> None:
        home = get_home()
        exec(["npm", "config", "set", f"prefix={home}/.npm"])
        exec(["npm", "config", "set", "min-release-age=7"])
        exec(["npm", "config", "set", "ignore-scripts=true"])

    def __install_global_packages(self) -> None:
        cmd = ["npm", "i", "-g"] + self.global_deps
        exec(cmd)

    @override
    def apply(self) -> None:
        if confirm("Install nodejs"):
            installer_path = self.__download_installer()
            self.__install_sources(installer_path)
            self.__install_support()
            self.__set_configs()

        if confirm("Install global dependencies"):
            self.__install_global_packages()


@dataclass
class PythonConfig(IConfig):
    system_packages: list[str]
    pip_packages: list[str]

    @override
    def name(self) -> str:
        return "Python"

    def __install_support(self) -> None:
        cmd = ["sudo", "apt-get", "install", "-y"] + self.system_packages
        exec(cmd)

    def __install_pip_packages(self) -> None:
        cmd = ["pipx", "install", "--force"] + self.pip_packages
        exec(cmd)

    @override
    def apply(self) -> None:
        if confirm("Install python support"):
            self.__install_support()

        if confirm("Install pip packages"):
            self.__install_pip_packages()


@dataclass
class WMConfig(IConfig):
    system_packages: list[str]

    @override
    def name(self) -> str:
        return "Xorg"

    def __install_packages(self) -> None:
        cmd = ["sudo", "apt-get", "install", "-y"] + self.system_packages
        exec(cmd)

    def __should_append(self) -> bool:
        with open("/etc/environment", "wt") as file:
            for line in file:
                if line.startswith("FREETYPE_PROPERTIES="):
                    return False
        return True

    def __improve_font_rendering(self) -> None:
        if self.__should_append():
            target_file = "/etc/environment"
            content = """FREETYPE_PROPERTIES="cff:no-stem-darkening=0 autofitter:no-stem-darkening=0" """
            cmd = f"echo '{content}' | sudo tee -a {target_file} > /dev/null"
            _ = subprocess.run(cmd, shell=True, check=True)

    @override
    def apply(self) -> None:
        if confirm("Install xorg packages"):
            self.__install_packages()

        if confirm("Improve font rendering"):
            self.__improve_font_rendering()


@dataclass
class SymlinksConfig(IConfig):
    @override
    def name(self) -> str:
        return "Symlinks"

    def __link_files(self, src_path: str, target_path: str) -> None:
        dir_entries = os.listdir(src_path)
        if not os.path.exists(target_path):
            os.mkdir(target_path)

        for entry in dir_entries:
            src = os.path.join(src_path, entry)
            dst = os.path.join(target_path, entry)

            if os.path.exists(dst):
                if os.path.islink(dst):
                    os.remove(dst)
                else:
                    backup = os.path.join(target_path, f"{entry}.old")
                    if os.path.exists(backup):
                        os.remove(backup)
                    os.rename(dst, backup)

            print(f"linking: {dst}")
            os.symlink(src, dst)

    @override
    def apply(self) -> None:
        if confirm("Link config files"):
            """link $HOME files"""
            target_dir = get_home()
            home_configs = os.path.join(os.getcwd(), "configs", "home")
            self.__link_files(home_configs, target_dir)

            """ link XDG_CONFIG files """
            target_dir = os.path.join(target_dir, ".config")
            xdg_configs = os.path.join(os.getcwd(), "configs", "config")
            self.__link_files(xdg_configs, target_dir)


# -------------------------------------------------------------------------------------------------------
#
#  configuration driver class.
#
# -------------------------------------------------------------------------------------------------------


class Config:
    symlink: SymlinksConfig
    system_packages: SystemPackagesConfig
    flatpak: FlatpakConfig
    docker: DockerConfig
    fish: FishConfig
    go: GoConfig
    nodejs: NodeJsConfig
    python: PythonConfig
    wm: WMConfig
    __steps: list[IConfig]

    def __init__(self) -> None:
        self.system_packages = SystemPackagesConfig(BASE_PACKAGES, COMMON_APPS)
        self.flatpak = FlatpakConfig(FLATPAK_PACKAGES)
        self.docker = DockerConfig(DOCKER_PACKAGES)
        self.fish = FishConfig()
        self.go = GoConfig(GO_VERSION, GO_PACKAGES)
        self.nodejs = NodeJsConfig(NODE_VERSION, NODE_GLOBAL_DEPS)
        self.python = PythonConfig(PYTHON_SYS_PACKAGES, PYTHON_PIP_PACKAGES)
        self.wm = WMConfig(WM_PACKAGES)
        self.symlink = SymlinksConfig()

        self.__steps = [
            self.symlink,
            self.system_packages,
            self.wm,
            self.flatpak,
            self.docker,
            self.fish,
            self.go,
            self.nodejs,
            self.python,
        ]

    def __parse_selection(self, selection: str) -> list[int]:
        if selection == "q" or selection == "Q":
            print(f"{COLOR_BLACK}Exiting...{COLOR_RESET}")
            sys.exit(0)

        pieces = selection.split(",")
        try:
            return [int(piece.strip()) for piece in pieces]
        except Exception:
            raise Exception("invalid selection")

    def __print_menu(self) -> list[int]:
        print(f"{COLOR_BLUE}Please select an options:{COLOR_RESET}")
        idx = 1
        for step in self.__steps:
            print(f"{idx:2d}. {step.name()}")
            idx += 1

        print(" q: Quit")
        selection = input(
            f"{COLOR_BLUE}Selection (separate with commas): {COLOR_RESET}"
        ).strip()
        return self.__parse_selection(selection)

    def __apply_selected(self, selection: list[int]) -> None:
        for s in selection:
            if s < 1 or s > len(self.__steps):
                raise Exception("invalid selection")

            target_step = self.__steps[s - 1]
            if not target_step:
                raise Exception("invalid selection")
            target_step.apply()

    def __apply_all(self) -> None:
        for step in self.__steps:
            step.apply()

    def __apply_configs(self) -> None:
        selection = self.__print_menu()
        if len(selection) == 0:
            self.__apply_all()
            return
        self.__apply_selected(selection)

    def execute(self) -> None:
        while True:
            self.__apply_configs()


# -------------------------------------------------------------------------------------------------------
#
#  script entrypoint.
#
# -------------------------------------------------------------------------------------------------------

if __name__ == "__main__":
    try:
        Config().execute()
    except KeyboardInterrupt:
        print(f"{COLOR_BLACK}\nctrl+c: Exiting...{COLOR_RESET}")
    except Exception as ex:
        print(f"{COLOR_RED}Error: {str(ex)}.{COLOR_RESET}")
